# SigInt Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Database (Supabase connection string)
DATABASE_URL=postgresql://user:password@host:5432/sigint

# Authentication
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (for LLM signal summaries - optional in MVP)
OPENAI_API_KEY=sk-...

# Resend (for email digests - optional in MVP)
RESEND_API_KEY=re_...
